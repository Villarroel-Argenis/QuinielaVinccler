@namespace QuinielaVinccler.UI.Web.Components.Admin
@using QuinielaVinccler.UI.Web.Components.Shared

<MudPaper Elevation="1" Class="pa-3 mb-3 rounded">
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
        Partido #@Partido.NumeroPartido
        <span style="opacity:0.6; margin-left:8px;">
            @Partido.FechaHoraUtc.ToLocalTime().ToString("ddd dd MMM · HH:mm")
        </span>
    </MudText>

    <div class="d-flex align-center gap-2 flex-wrap">

        @* ── Slot local ──────────────────────────────────────────────────── *@
        <div class="d-flex flex-column" style="min-width:200px; flex:1;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                @Partido.SlotLocal
            </MudText>
            <MudEquipoSelect Value="EquipoLocalId"
                             ValueChanged="async v => await OnEquipoLocalChanged.InvokeAsync(v)"
                             Items="CandidatosLocal"
                             EquiposById="EquiposById"
                             Disabled="false"
                             Clearable="true"
                             MinWidth="100%" />
        </div>

        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mx-1 mt-3">vs</MudText>

        @* ── Slot visitante ───────────────────────────────────────────────── *@
        <div class="d-flex flex-column" style="min-width:200px; flex:1;">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                @Partido.SlotVisitante
            </MudText>
            <MudEquipoSelect Value="EquipoVisitanteId"
                             ValueChanged="async v => await OnEquipoVisitanteChanged.InvokeAsync(v)"
                             Items="CandidatosVisitante"
                             EquiposById="EquiposById"
                             Disabled="false"
                             Clearable="true"
                             MinWidth="100%" />
        </div>
    </div>
</MudPaper>
