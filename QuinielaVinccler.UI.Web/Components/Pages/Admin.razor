@page "/admin"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "SoloAdmin")]
@using QuinielaVinccler.UI.Web.Components.Admin

<PageTitle>Panel Administrador</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-4">Panel de Administrador</MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">

        <MudTabPanel Text="Generar Planillas" Icon="@Icons.Material.Filled.Add">
            <LoteComponent />
        </MudTabPanel>

        <MudTabPanel Text="Gestión de Planillas" Icon="@Icons.Material.Filled.ManageSearch">
            <GestionPlanillasComponent />
        </MudTabPanel>

        <MudTabPanel Text="Resultados" Icon="@Icons.Material.Filled.SportsSoccer">
            <ResultadosComponent />
        </MudTabPanel>

        <MudTabPanel Text="Configuración" Icon="@Icons.Material.Filled.Settings">
            <ConfiguracionComponent />
        </MudTabPanel>

    </MudTabs>
</MudContainer>
