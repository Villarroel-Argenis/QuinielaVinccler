@* Components/Shared/ManualDialog.razor *@
@using QuinielaVinccler.UI.Web.Services

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Help" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Manual de uso</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="manual-content">
            @((MarkupString)_html)
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cerrar" Variant="Variant.Filled" Color="Color.Primary">
            Cerrar
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .manual-content h1 {
        font-size: 1.6rem;
        font-weight: 700;
        margin: 1.5rem 0 0.8rem;
        color: var(--mud-palette-primary);
        border-bottom: 2px solid var(--mud-palette-primary);
        padding-bottom: 0.3rem;
    }
    .manual-content h2 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 1.3rem 0 0.6rem;
        color: var(--mud-palette-text-primary);
    }
    .manual-content h3 {
        font-size: 1.05rem;
        font-weight: 600;
        margin: 1rem 0 0.4rem;
    }
    .manual-content p {
        margin-bottom: 0.8rem;
        line-height: 1.6;
    }
    .manual-content ul,
    .manual-content ol {
        margin-bottom: 0.8rem;
        padding-left: 1.5rem;
    }
    .manual-content li {
        margin-bottom: 0.3rem;
        line-height: 1.5;
    }
    .manual-content blockquote {
        border-left: 4px solid var(--mud-palette-warning);
        background: var(--mud-palette-warning-lighten);
        padding: 0.6rem 1rem;
        margin: 0.8rem 0;
        border-radius: 4px;
    }
    .manual-content code {
        background: var(--mud-palette-action-disabled-background);
        padding: 2px 6px;
        border-radius: 3px;
        font-family: 'Consolas', monospace;
        font-size: 0.9em;
    }
    .manual-content hr {
        margin: 2rem 0;
        border: none;
        border-top: 1px solid var(--mud-palette-divider);
    }
    .manual-content strong {
        font-weight: 600;
    }
</style>
