@page "/planilla/{PlanillaId:int}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Registrado")]
@using QuinielaVinccler.UI.Web.Components.Shared

<PageTitle>@(_planilla?.Codigo ?? "Planilla") – Quiniela FIFA 2026</PageTitle>

@if (_cargando)
{
    <div class="d-flex justify-center pa-16">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else if (_planilla is null)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 text-center">
        <MudText Typo="Typo.h6">Planilla no encontrada.</MudText>
        <MudButton Href="/mis-planillas" Class="mt-4">Volver</MudButton>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

        @* ── Header ────────────────────────────────────────────────────────── *@
        <div class="d-flex align-center justify-space-between flex-wrap gap-2 mb-4">
            <div class="d-flex align-center gap-3">
                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Href="/mis-planillas">
                    Mis Planillas
                </MudButton>
                <MudText Typo="Typo.h6" Style="font-weight:700;">@_planilla.Codigo</MudText>
                <MudChip T="string" Size="Size.Small"
                         Color="@(_soloLectura ? Color.Default : Color.Primary)">
                    @(_soloLectura ? "Solo lectura" : "Editable")
                </MudChip>
            </div>
            <MudText Typo="Typo.body1">
                <strong>@_camposCompletos</strong> / @TotalCampos completados
            </MudText>
        </div>

        @if (_soloLectura)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">
                La quiniela está cerrada. Estás viendo tu planilla en modo solo lectura.
            </MudAlert>
        }

        @if (!_soloLectura)
        {
            <div class="d-flex justify-end mb-2">
                <MudButton Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.RestartAlt"
                           OnClick="AbrirResetTotal">
                    Resetear todo
                </MudButton>
            </div>
        }

        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

            @* ── Fase de Grupos ───────────────────────────────────────────── *@
            <MudTabPanel Text="Fase de Grupos">
                @foreach (var (grupo, preds) in _grupoMap)
                {
                    @* ── Header de grupo ── *@
                    <div class="d-flex align-center px-1 pt-4 pb-1 mb-1">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Grupo @grupo</MudText>
                    </div>
                    <MudPaper Elevation="1" Class="mb-3 rounded">
                        @foreach (var pred in preds)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 pa-3">
                                Partido #@pred.Partido.NumeroPartido
                                <span style="opacity:0.6; margin-left:8px;">
                                    @pred.Partido.FechaHoraUtc.ToLocalTime().ToString("ddd dd MMM · HH:mm")
                                </span>
                            </MudText>
                            <div class="grupo-fila px-3" style="border-bottom:1px solid rgba(0,0,0,.08);">

                                @* ── Equipos ── *@
                                <div class="grupo-fila__equipos">
                                    <div class="d-flex align-center gap-1" style="min-width:0;">
                                        <img src="@pred.Partido.EquipoLocal!.FlagUrl"
                                             style="height:16px; flex-shrink:0;" />
                                        <MudText Typo="Typo.body2"
                                                 Style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                            @pred.Partido.EquipoLocal.Nombre
                                        </MudText>
                                    </div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                             Style="flex-shrink:0; padding:0 4px;">vs</MudText>
                                    <div class="d-flex align-center gap-1" style="min-width:0;">
                                        <img src="@pred.Partido.EquipoVisitante!.FlagUrl"
                                             style="height:16px; flex-shrink:0;" />
                                        <MudText Typo="Typo.body2"
                                                 Style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                            @pred.Partido.EquipoVisitante.Nombre
                                        </MudText>
                                    </div>
                                </div>

                                @* ── Botones 1/X/2 ── *@
                                <div class="grupo-fila__botones">
                                    @foreach (var r in new[] { ResultadoPartido.Uno, ResultadoPartido.Equis, ResultadoPartido.Dos })
                                    {
                                        <MudButton Size="Size.Small"
                                                   Variant="@(pred.ResultadoPredicho == r ? Variant.Filled : Variant.Outlined)"
                                                   Color="@(pred.ResultadoPredicho == r ? Color.Primary : Color.Default)"
                                                   OnClick="() => GuardarGrupo(pred, pred.ResultadoPredicho == r ? (ResultadoPartido?)null : r)"
                                                   Disabled="_soloLectura"
                                                   Style="min-width:36px; padding:0 4px;">
                                            @GetLabelResultado(r)
                                        </MudButton>
                                    }
                                    @if (!_soloLectura && pred.ResultadoPredicho.HasValue)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                                       Size="Size.Small" Color="Color.Error"
                                                       OnClick="() => GuardarGrupo(pred, null)" />
                                    }
                                    @if (TieneCheckmark($"g-{pred.Id}"))
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                 Color="Color.Success" Size="Size.Small" />
                                    }
                                </div>
                            </div>
                        }
                    </MudPaper>
                }
            </MudTabPanel>

            @* ── Fases eliminatorias ──────────────────────────────────────── *@
            <MudTabPanel Text="Dieciseisavos">
                @if (!_soloLectura)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4"
                              Icon="@Icons.Material.Filled.Lightbulb">
                        <strong>Recomendación:</strong> Completa primero los <strong>primeros</strong> y
                        <strong>segundos</strong> de cada grupo — esos slots se llenan libremente.
                        Los <strong>mejores terceros</strong> dependen de qué grupos aún no hayan sido usados,
                        así que complétalos de último.
                    </MudAlert>
                }
                @foreach (var pred in _r32)
                {
                    var keyL = $"kol-{pred.Id}";
                    var keyV = $"kov-{pred.Id}";
                    <KnockoutRow Pred="pred"
                                 EquiposById="_equiposById"
                                 GetCandidatos="GetCandidatosParaSlot"
                                 SoloLectura="_soloLectura"
                                 MostrarCheckmarkLocal="@TieneCheckmark(keyL)"
                                 MostrarCheckmarkVisitante="@TieneCheckmark(keyV)"
                                 OnLocalChanged="async v => await GuardarKoLocal(pred, v)"
                                 OnVisitanteChanged="async v => await GuardarKoVisitante(pred, v)" />
                }
            </MudTabPanel>

            <MudTabPanel Text="Octavos">
                @foreach (var pred in _r16)
                {
                    var keyL = $"kol-{pred.Id}";
                    var keyV = $"kov-{pred.Id}";
                    <KnockoutRow Pred="pred"
                                 EquiposById="_equiposById"
                                 GetCandidatos="GetCandidatosParaSlot"
                                 SoloLectura="_soloLectura"
                                 MostrarCheckmarkLocal="@TieneCheckmark(keyL)"
                                 MostrarCheckmarkVisitante="@TieneCheckmark(keyV)"
                                 OnLocalChanged="async v => await GuardarKoLocal(pred, v)"
                                 OnVisitanteChanged="async v => await GuardarKoVisitante(pred, v)" />
                }
            </MudTabPanel>

            <MudTabPanel Text="Cuartos de Final">
                @foreach (var pred in _cuartos)
                {
                    var keyL = $"kol-{pred.Id}";
                    var keyV = $"kov-{pred.Id}";
                    <KnockoutRow Pred="pred"
                                 EquiposById="_equiposById"
                                 GetCandidatos="GetCandidatosParaSlot"
                                 SoloLectura="_soloLectura"
                                 MostrarCheckmarkLocal="@TieneCheckmark(keyL)"
                                 MostrarCheckmarkVisitante="@TieneCheckmark(keyV)"
                                 OnLocalChanged="async v => await GuardarKoLocal(pred, v)"
                                 OnVisitanteChanged="async v => await GuardarKoVisitante(pred, v)" />
                }
            </MudTabPanel>

            <MudTabPanel Text="Semifinales">
                @foreach (var pred in _semis)
                {
                    var keyL = $"kol-{pred.Id}";
                    var keyV = $"kov-{pred.Id}";
                    <KnockoutRow Pred="pred"
                                 EquiposById="_equiposById"
                                 GetCandidatos="GetCandidatosParaSlot"
                                 SoloLectura="_soloLectura"
                                 MostrarCheckmarkLocal="@TieneCheckmark(keyL)"
                                 MostrarCheckmarkVisitante="@TieneCheckmark(keyV)"
                                 OnLocalChanged="async v => await GuardarKoLocal(pred, v)"
                                 OnVisitanteChanged="async v => await GuardarKoVisitante(pred, v)" />
                }
            </MudTabPanel>

            <MudTabPanel Text="3° y 4° Puesto">
                @if (_tercero is not null)
                {
                    var keyL = $"kol-{_tercero.Id}";
                    var keyV = $"kov-{_tercero.Id}";
                    <KnockoutRow Pred="_tercero"
                                 EquiposById="_equiposById"
                                 GetCandidatos="GetCandidatosParaSlot"
                                 SoloLectura="_soloLectura"
                                 MostrarCheckmarkLocal="@TieneCheckmark(keyL)"
                                 MostrarCheckmarkVisitante="@TieneCheckmark(keyV)"
                                 OnLocalChanged="async v => await GuardarKoLocal(_tercero, v)"
                                 OnVisitanteChanged="async v => await GuardarKoVisitante(_tercero, v)" />
                }
            </MudTabPanel>

            <MudTabPanel Text="Gran Final">
                @if (_finalMatch is not null)
                {
                    var keyL = $"kol-{_finalMatch.Id}";
                    var keyV = $"kov-{_finalMatch.Id}";
                    <MudText Typo="Typo.subtitle2" Class="mb-3">
                        Partido #@_finalMatch.Partido.NumeroPartido — ¿Quiénes llegan a la final?
                    </MudText>
                    <KnockoutRow Pred="_finalMatch"
                                 EquiposById="_equiposById"
                                 GetCandidatos="GetCandidatosParaSlot"
                                 SoloLectura="_soloLectura"
                                 MostrarCheckmarkLocal="@TieneCheckmark(keyL)"
                                 MostrarCheckmarkVisitante="@TieneCheckmark(keyV)"
                                 OnLocalChanged="async v => await GuardarKoLocal(_finalMatch, v)"
                                 OnVisitanteChanged="async v => await GuardarKoVisitante(_finalMatch, v)" />
                    <MudDivider Class="my-4" />
                }

                @if (_pFinal is not null)
                {
                    <MudGrid>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-3">
                                Posiciones finales
                            </MudText>
                        </MudItem>

                        @{
                            // Variables locales para evitar comillas anidadas en atributos
                            var campeonKey = "f-campeon";
                            var segundoKey = "f-segundo";
                            var terceroKey = "f-tercero";
                            var cuartoKey = "f-cuarto";
                            var masGolKey = "f-masGoleador";
                            var masGoldKey = "f-masGoleado";
                            var menosGolKey = "f-menosGoleado";
                        }

                        <FinalEquipoRow Label="Campeón (300 pts)"
                                        ValorActual="_pFinal.CampeonEquipoId"
                                        Equipos="_equipos"
                                        EquiposById="_equiposById"
                                        SoloLectura="_soloLectura"
                                        MostrarCheckmark="@TieneCheckmark(campeonKey)"
                                        OnValorChanged="async v => await CambiarFinalEquipo(campeonKey, v, () => _pFinal.CampeonEquipoId, x => _pFinal.CampeonEquipoId = x)" />

                        <FinalEquipoRow Label="2° Lugar (200 pts)"
                                        ValorActual="_pFinal.SegundoLugarEquipoId"
                                        Equipos="_equipos"
                                        EquiposById="_equiposById"
                                        SoloLectura="_soloLectura"
                                        MostrarCheckmark="@TieneCheckmark(segundoKey)"
                                        OnValorChanged="async v => await CambiarFinalEquipo(segundoKey, v, () => _pFinal.SegundoLugarEquipoId, x => _pFinal.SegundoLugarEquipoId = x)" />

                        <FinalEquipoRow Label="3er Lugar (100 pts)"
                                        ValorActual="_pFinal.TercerLugarEquipoId"
                                        Equipos="_equipos"
                                        EquiposById="_equiposById"
                                        SoloLectura="_soloLectura"
                                        MostrarCheckmark="@TieneCheckmark(terceroKey)"
                                        OnValorChanged="async v => await CambiarFinalEquipo(terceroKey, v, () => _pFinal.TercerLugarEquipoId, x => _pFinal.TercerLugarEquipoId = x)" />

                        <FinalEquipoRow Label="4° Lugar (50 pts)"
                                        ValorActual="_pFinal.CuartoLugarEquipoId"
                                        Equipos="_equipos"
                                        EquiposById="_equiposById"
                                        SoloLectura="_soloLectura"
                                        MostrarCheckmark="@TieneCheckmark(cuartoKey)"
                                        OnValorChanged="async v => await CambiarFinalEquipo(cuartoKey, v, () => _pFinal.CuartoLugarEquipoId, x => _pFinal.CuartoLugarEquipoId = x)" />

                        <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-3">
                                Extras fase eliminatoria (100 pts c/u)
                            </MudText>
                        </MudItem>

                        <FinalEquipoRow Label="Equipo más goleador (Fase eliminatoria)"
                                        ValorActual="_pFinal.MasGoleadorEquipoId"
                                        Equipos="_equipos"
                                        EquiposById="_equiposById"
                                        SoloLectura="_soloLectura"
                                        MostrarCheckmark="@TieneCheckmark(masGolKey)"
                                        OnValorChanged="async v => await CambiarFinalEquipo(masGolKey, v, () => _pFinal.MasGoleadorEquipoId, x => _pFinal.MasGoleadorEquipoId = x)" />

                        <FinalEquipoRow Label="Equipo más goleado (Fase eliminatoria)"
                                        ValorActual="_pFinal.MasGoleadoEquipoId"
                                        Equipos="_equipos"
                                        EquiposById="_equiposById"
                                        SoloLectura="_soloLectura"
                                        MostrarCheckmark="@TieneCheckmark(masGoldKey)"
                                        OnValorChanged="async v => await CambiarFinalEquipo(masGoldKey, v, () => _pFinal.MasGoleadoEquipoId, x => _pFinal.MasGoleadoEquipoId = x)" />

                        <FinalEquipoRow Label="Equipo menos goleado (Fase eliminatoria)"
                                        ValorActual="_pFinal.MenosGoleadoEquipoId"
                                        Equipos="_equipos"
                                        EquiposById="_equiposById"
                                        SoloLectura="_soloLectura"
                                        MostrarCheckmark="@TieneCheckmark(menosGolKey)"
                                        OnValorChanged="async v => await CambiarFinalEquipo(menosGolKey, v, () => _pFinal.MenosGoleadoEquipoId, x => _pFinal.MenosGoleadoEquipoId = x)" />

                        <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-3">
                                Resultados exactos a 90 minutos (100 pts c/u)
                            </MudText>
                        </MudItem>

                        @FilaScore("Resultados Semi Final 1 · a los 90 min (Partido #101)", "sf1L", "sf1V",
                            _pFinal.GolesLocalSemi1, _pFinal.GolesVisitanteSemi1,
                            v => { _pFinal.GolesLocalSemi1 = v; }, v => { _pFinal.GolesVisitanteSemi1 = v; })

                        @FilaScore("Resultados Semi Final 2 · a los 90 min (Partido #102)", "sf2L", "sf2V",
                            _pFinal.GolesLocalSemi2, _pFinal.GolesVisitanteSemi2,
                            v => { _pFinal.GolesLocalSemi2 = v; }, v => { _pFinal.GolesVisitanteSemi2 = v; })

                        @FilaScore("Resultados Gran Final · a los 90 min (Partido #104)", "finL", "finV",
                            _pFinal.GolesLocalGranFinal, _pFinal.GolesVisitanteGranFinal,
                            v => { _pFinal.GolesLocalGranFinal = v; }, v => { _pFinal.GolesVisitanteGranFinal = v; })
                    </MudGrid>
                }
            </MudTabPanel>
        </MudTabs>
    </MudContainer>

    <MudDialog @bind-Visible="_showResetTotal">
        <TitleContent>
            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
                <MudText Typo="Typo.h6">Resetear planilla</MudText>
            </div>
        </TitleContent>
        <DialogContent>
            <MudText Class="mb-3">
                ¿Estás seguro que deseas resetear la planilla <strong>@_planilla.Codigo</strong>?
            </MudText>
            <MudAlert Severity="Severity.Error" Dense="true">
                Esta acción borrará <strong>todas tus predicciones</strong>.
                La planilla quedará vinculada pero sin ninguna selección. No se puede deshacer.
            </MudAlert>
            @if (_errorReset is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_errorReset</MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CerrarResetTotal" Disabled="_resetando">Cancelar</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       OnClick="ConfirmarResetTotal" Disabled="_resetando"
                       StartIcon="@Icons.Material.Filled.RestartAlt">
                @if (_resetando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Reseteando...</span>
                }
                else
                {
                    <span>Sí, resetear todo</span>
                }
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    // FilaScore permanece como RenderFragment local — solo MudNumericField,
    // sin SelectedItemTemplate, sin problema de context.
    RenderFragment FilaScore(string label, string campoL, string campoV,
        int? golesL, int? golesV, Action<int?> setL, Action<int?> setV) =>
        @<MudItem xs="12" sm="6">
            <MudText Typo="Typo.body2" Class="mb-1">@label</MudText>
            <div class="d-flex align-center gap-2">
                <MudNumericField T="int?" Value="golesL"
                                 ValueChanged="async v => { var ant = golesL; setL(v); await GuardarFinal(campoL, ant.HasValue, v.HasValue); }"
                                 Disabled="_soloLectura" Min="0" Max="99"
                                 Variant="Variant.Outlined" Dense="true" Style="width:70px;" />
                <MudText>-</MudText>
                <MudNumericField T="int?" Value="golesV"
                                 ValueChanged="async v => { var ant = golesV; setV(v); await GuardarFinal(campoV, ant.HasValue, v.HasValue); }"
                                 Disabled="_soloLectura" Min="0" Max="99"
                                 Variant="Variant.Outlined" Dense="true" Style="width:70px;" />
                @if (TieneCheckmark($"f-{campoL}") || TieneCheckmark($"f-{campoV}"))
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
            </div>
        </MudItem>;
}

<style>
    /* ── Fila de partido en fase de grupos ─────────────────────────────────── */

    /* fecha arriba full-width, equipos y botones en segunda fila */
    .grupo-fila {
        display: grid;
        grid-template-columns: 1fr auto;
        grid-template-rows: auto auto;
        align-items: center;
        gap: 2px 8px;
        padding: 8px 0;
    }

    .partido-fecha {
        grid-column: 1 / -1;
        opacity: 0.6;
        font-size: 0.7rem;
    }

    .grupo-fila__equipos {
        display: flex;
        align-items: center;
        min-width: 0;
        overflow: hidden;
        gap: 4px;
    }

        .grupo-fila__equipos > div {
            flex: 1;
            min-width: 0;
        }

    .grupo-fila__botones {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-shrink: 0;
    }

    /* Mobile: cada equipo en su propia línea, botones debajo */
    @@media (max-width: 480px) {
        .grupo-fila {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: 6px;
        }

        .grupo-fila__equipos {
            flex-direction: column;
            align-items: flex-start;
            gap: 2px;
        }

            .grupo-fila__equipos > div {
                width: 100%;
            }

        .grupo-fila__botones {
            justify-content: flex-start;
            padding-top: 2px;
        }
    }
</style>
