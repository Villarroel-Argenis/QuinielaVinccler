@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using QuinielaVinccler.UI.Web.Components.Layout
@using QuinielaVinccler.UI.Web.Components.Shared
@inject IDialogService DialogSvc

<MudThemeProvider Theme="AppTheme.Theme"
                  @bind-IsDarkMode="_isDarkMode"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <img src="/images/logo-vinccler.svg" alt="Vinccler" style="height:55px;" class="mr-3" />
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="DrawerToggle" />
        <svg xmlns="http://www.w3.org/2000/svg" height="32" viewBox="0 0 24 24" fill="white" class="mr-2">
            <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94A5.01 5.01 0 0011
                     15.9V18H9v2h6v-2h-2v-2.1a5.01 5.01 0 003.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5
                     8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z" />
        </svg>
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudText Typo="Typo.h6" Style="color:white;">Quiniela FIFA 2026</MudText>
        </MudHidden>

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="Manual de uso">
                    <MudIconButton Icon="@Icons.Material.Filled.Help"
                                   Color="Color.Inherit"
                                   OnClick="@(() => AbrirManual(context.User.IsInRole("Admin")))" />
                </MudTooltip>
            </Authorized>
        </AuthorizeView>

        <MudIconButton Icon="@DarkLightModeButtonIcon"
                       Color="Color.Inherit"
                       OnClick="DarkModeToggle" />

        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="Cerrar sesión">
                    <form method="post" action="/api/auth/signout" style="display:contents;">
                        <AntiforgeryToken />
                        <MudIconButton ButtonType="ButtonType.Submit"
                                       Icon="@Icons.Material.Filled.Logout"
                                       Color="Color.Inherit"
                                       Edge="Edge.End" />
                    </form>
                </MudTooltip>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer id="nav-drawer"
               @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private async Task AbrirManual(bool esAdmin)
    {
        var parametros = new DialogParameters<ManualDialog>
        {
            { x => x.MostrarAdmin, esAdmin }
        };

        var opciones = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        await DialogSvc.ShowAsync<ManualDialog>("Manual de uso", parametros, opciones);
    }
}
