@page "/planilla/{PlanillaId:int}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Registrado")]

<PageTitle>@(_planilla?.Codigo ?? "Planilla") – Quiniela FIFA 2026</PageTitle>

@if (_cargando)
{
    <div class="d-flex justify-center pa-16">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else if (_planilla is null)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 text-center">
        <MudText Typo="Typo.h6">Planilla no encontrada.</MudText>
        <MudButton Href="/mis-planillas" Class="mt-4">Volver</MudButton>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

        @* ── Header ────────────────────────────────────────────────────────── *@
        <div class="d-flex align-center justify-space-between flex-wrap gap-2 mb-4">
            <div class="d-flex align-center gap-3">
                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Href="/mis-planillas">
                    Mis Planillas
                </MudButton>
                <MudText Typo="Typo.h6" Style="font-weight:700;">@_planilla.Codigo</MudText>
                <MudChip T="string" Size="Size.Small"
                         Color="@(_soloLectura ? Color.Default : Color.Primary)">
                    @(_soloLectura ? "Solo lectura" : "Editable")
                </MudChip>
            </div>
            <MudText Typo="Typo.body1">
                <strong>@_camposCompletos</strong> / @TotalCampos completados
            </MudText>
        </div>

        @if (_soloLectura)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">
                La quiniela está cerrada. Estás viendo tu planilla en modo solo lectura.
            </MudAlert>
        }

        @if (!_soloLectura)
        {
            <div class="d-flex justify-end mb-2">
                <MudButton Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.RestartAlt"
                           OnClick="AbrirResetTotal">
                    Resetear todo
                </MudButton>
            </div>
        }

        @* ── Tabs ──────────────────────────────────────────────────────────── *@
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

            @* ── Fase de Grupos ───────────────────────────────────────────── *@
            <MudTabPanel Text="Fase de Grupos">
                <MudExpansionPanels MultiExpansion="true">
                    @foreach (var (grupo, preds) in _grupoMap)
                    {
                        <MudExpansionPanel>
                            <TitleContent>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Grupo @grupo</MudText>
                            </TitleContent>
                            <ChildContent>
                                @foreach (var pred in preds)
                                {
                                    <div class="d-flex align-center justify-space-between flex-wrap gap-2 py-2"
                                         style="border-bottom:1px solid rgba(0,0,0,.08);">
                                        <div class="d-flex align-center gap-4" style="min-width:280px;">
                                            <div class="d-flex align-center gap-1">
                                                <img src="@pred.Partido.EquipoLocal!.FlagUrl" style="height:16px;" />
                                                <MudText Typo="Typo.body2">@pred.Partido.EquipoLocal.Nombre</MudText>
                                            </div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">vs</MudText>
                                            <div class="d-flex align-center gap-1">
                                                <img src="@pred.Partido.EquipoVisitante!.FlagUrl" style="height:16px;" />
                                                <MudText Typo="Typo.body2">@pred.Partido.EquipoVisitante.Nombre</MudText>
                                            </div>
                                        </div>
                                        <div class="d-flex align-center gap-1">
                                            @foreach (var r in new[] { ResultadoPartido.Uno, ResultadoPartido.Equis, ResultadoPartido.Dos })
                                            {
                                                <MudButton Size="Size.Small"
                                                           Variant="@(pred.ResultadoPredicho == r ? Variant.Filled : Variant.Outlined)"
                                                           Color="@(pred.ResultadoPredicho == r ? Color.Primary : Color.Default)"
                                                           OnClick="() => GuardarGrupo(pred, pred.ResultadoPredicho == r ? (ResultadoPartido?)null : r)"
                                                           Disabled="_soloLectura"
                                                           Style="min-width:40px;">
                                                    @GetLabelResultado(r)
                                                </MudButton>
                                            }
                                            @if (!_soloLectura && pred.ResultadoPredicho.HasValue)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                                               Size="Size.Small" Color="Color.Error"
                                                               OnClick="() => GuardarGrupo(pred, null)" />
                                            }
                                            @if (TieneCheckmark($"g-{pred.Id}"))
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                         Color="Color.Success" Size="Size.Small" />
                                            }
                                        </div>
                                    </div>
                                }
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            </MudTabPanel>

            @* ── Dieciseisavos ────────────────────────────────────────────── *@
            <MudTabPanel Text="Dieciseisavos">
                @TabKnockout(_r32)
            </MudTabPanel>

            @* ── Octavos ──────────────────────────────────────────────────── *@
            <MudTabPanel Text="Octavos">
                @TabKnockout(_r16)
            </MudTabPanel>

            @* ── Cuartos ──────────────────────────────────────────────────── *@
            <MudTabPanel Text="Cuartos de Final">
                @TabKnockout(_cuartos)
            </MudTabPanel>

            @* ── Semifinales ──────────────────────────────────────────────── *@
            <MudTabPanel Text="Semifinales">
                @TabKnockout(_semis)
            </MudTabPanel>

            @* ── 3ro y 4to ────────────────────────────────────────────────── *@
            <MudTabPanel Text="3° y 4° Puesto">
                @if (_tercero is not null)
                {
                    @FilaKnockout(_tercero)
                }
            </MudTabPanel>

            @* ── Gran Final ───────────────────────────────────────────────── *@
            <MudTabPanel Text="Gran Final">
                @if (_finalMatch is not null)
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-3">
                        Partido #@_finalMatch.Partido.NumeroPartido — ¿Quiénes llegan a la final?
                    </MudText>
                    @FilaKnockout(_finalMatch)
                    <MudDivider Class="my-4" />
                }

                @if (_pFinal is not null)
                {
                    <MudGrid>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-3">
                                Posiciones finales
                            </MudText>
                        </MudItem>

                        @FilaFinalEquipo("Campeón (300 pts)",  "campeon",     _pFinal.CampeonEquipoId,      v => { _pFinal.CampeonEquipoId = v; })
                        @FilaFinalEquipo("2° Lugar (200 pts)", "segundo",     _pFinal.SegundoLugarEquipoId, v => { _pFinal.SegundoLugarEquipoId = v; })
                        @FilaFinalEquipo("3er Lugar (100 pts)","tercero",     _pFinal.TercerLugarEquipoId,  v => { _pFinal.TercerLugarEquipoId = v; })
                        @FilaFinalEquipo("4° Lugar (50 pts)",  "cuarto",      _pFinal.CuartoLugarEquipoId,  v => { _pFinal.CuartoLugarEquipoId = v; })

                        <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-3">
                                Extras fase de grupos (100 pts c/u)
                            </MudText>
                        </MudItem>

                        @FilaFinalEquipo("Equipo más goleador",  "masGoleador",  _pFinal.MasGoleadorEquipoId,  v => { _pFinal.MasGoleadorEquipoId = v; })
                        @FilaFinalEquipo("Equipo más goleado",   "masGoleado",   _pFinal.MasGoleadoEquipoId,   v => { _pFinal.MasGoleadoEquipoId = v; })
                        @FilaFinalEquipo("Equipo menos goleado", "menosGoleado", _pFinal.MenosGoleadoEquipoId, v => { _pFinal.MenosGoleadoEquipoId = v; })

                        <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-3">
                                Resultados exactos a 90 minutos (100 pts c/u)
                            </MudText>
                        </MudItem>

                        @FilaScore("Semifinal 1 (Partido #101)", "sf1L", "sf1V",
                            _pFinal.GolesLocalSemi1, _pFinal.GolesVisitanteSemi1,
                            v => { _pFinal.GolesLocalSemi1 = v; }, v => { _pFinal.GolesVisitanteSemi1 = v; })

                        @FilaScore("Semifinal 2 (Partido #102)", "sf2L", "sf2V",
                            _pFinal.GolesLocalSemi2, _pFinal.GolesVisitanteSemi2,
                            v => { _pFinal.GolesLocalSemi2 = v; }, v => { _pFinal.GolesVisitanteSemi2 = v; })

                        @FilaScore("Gran Final (Partido #104)", "finL", "finV",
                            _pFinal.GolesLocalGranFinal, _pFinal.GolesVisitanteGranFinal,
                            v => { _pFinal.GolesLocalGranFinal = v; }, v => { _pFinal.GolesVisitanteGranFinal = v; })
                    </MudGrid>
                }
            </MudTabPanel>
        </MudTabs>
    </MudContainer>

    @* ── Diálogo Reset Total ────────────────────────────────────────────────── *@
    <MudDialog @bind-Visible="_showResetTotal">
        <TitleContent>
            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
                <MudText Typo="Typo.h6">Resetear planilla</MudText>
            </div>
        </TitleContent>
        <DialogContent>
            <MudText Class="mb-3">
                ¿Estás seguro que deseas resetear la planilla <strong>@_planilla.Codigo</strong>?
            </MudText>
            <MudAlert Severity="Severity.Error" Dense="true">
                Esta acción borrará <strong>todas tus predicciones</strong>.
                La planilla quedará vinculada pero sin ninguna selección. No se puede deshacer.
            </MudAlert>
            @if (_errorReset is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_errorReset</MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CerrarResetTotal" Disabled="_resetando">Cancelar</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       OnClick="ConfirmarResetTotal" Disabled="_resetando"
                       StartIcon="@Icons.Material.Filled.RestartAlt">
                @if (_resetando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Reseteando...</span>
                }
                else { <span>Sí, resetear todo</span> }
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@* ── Render fragments ─────────────────────────────────────────────────────── *@
@code {
    // Tab con lista de partidos knockout (mismo patrón para todos)
    RenderFragment TabKnockout(List<PrediccionKnockout> preds) =>
        @<div>@foreach (var pred in preds) { @FilaKnockout(pred) }</div>;

    // Fila de partido knockout con 2 slots (local + visitante)
    RenderFragment FilaKnockout(PrediccionKnockout pred) =>
        @<MudPaper Elevation="1" Class="pa-3 mb-3 rounded">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                Partido #@pred.Partido.NumeroPartido
            </MudText>
            <div class="d-flex align-center gap-2 flex-wrap">

                @* Slot local *@
                <div class="d-flex flex-column" style="min-width:200px;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                        @pred.Partido.SlotLocal
                    </MudText>
                    <div class="d-flex align-center gap-1">
                        <MudSelect T="int?"
                                   Value="pred.EquipoLocalPredichoId"
                                   ValueChanged="async v => await GuardarKoLocal(pred, v)"
                                   Disabled="_soloLectura" Dense="true"
                                   Variant="Variant.Outlined"
                                   Placeholder="Seleccionar">
                            <MudSelectItem T="int?" Value="(int?)null">-- Seleccionar --</MudSelectItem>
                        @if (EsSlotMejorTercero(pred.Partido.SlotLocal))
                        {
                            @foreach (var grupo in GetCandidatosParaSlot(
                                    pred.Partido.SlotLocal,
                                    pred.EquipoVisitantePredichoId,
                                    pred.Id)
                                    .GroupBy(e => e.Grupo)
                                    .OrderBy(g => g.Key))
                            {
                                

                                @foreach (var eq in grupo)
                                {
                                    <MudSelectItem T="int?" Value="(int?)eq.Id">
                                        <div class="d-flex align-center gap-1">
                                            <img src="@eq.FlagUrl" style="height:14px;" />
                                            @eq.Nombre
                                        </div>
                                    </MudSelectItem>
                                }
                            }
                        }
                        else
                        {
                            @foreach (var eq in GetCandidatosParaSlot(
                                    pred.Partido.SlotLocal,
                                    pred.EquipoVisitantePredichoId,
                                    pred.Id))
                            {
                                <MudSelectItem T="int?" Value="(int?)eq.Id">
                                    <div class="d-flex align-center gap-1">
                                        <img src="@eq.FlagUrl" style="height:14px;" />
                                        @eq.Nombre
                                    </div>
                                </MudSelectItem>
                            }
                        }
                    </MudSelect>
                        @if (!_soloLectura && pred.EquipoLocalPredichoId.HasValue)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                           Size="Size.Small" Color="Color.Error"
                                           OnClick="async () => await GuardarKoLocal(pred, null)" />
                        }
                        @if (TieneCheckmark($"kol-{pred.Id}"))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                     Color="Color.Success" Size="Size.Small" />
                        }
                    </div>
                </div>

                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mx-1 mt-3">vs</MudText>

                @* Slot visitante *@
                <div class="d-flex flex-column" style="min-width:200px;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                        @pred.Partido.SlotVisitante
                    </MudText>
                    <div class="d-flex align-center gap-1">
                        <MudSelect T="int?"
                                   Value="pred.EquipoVisitantePredichoId"
                                   ValueChanged="async v => await GuardarKoVisitante(pred, v)"
                                   Disabled="_soloLectura" Dense="true"
                                   Variant="Variant.Outlined"
                                   Placeholder="Seleccionar">
                            <MudSelectItem T="int?" Value="(int?)null">-- Seleccionar --</MudSelectItem>
                        @if (EsSlotMejorTercero(pred.Partido.SlotVisitante))
                        {
                            @foreach (var grupo in GetCandidatosParaSlot(
                                    pred.Partido.SlotVisitante,
                                    pred.EquipoLocalPredichoId,
                                    pred.Id)
                                    .GroupBy(e => e.Grupo)
                                    .OrderBy(g => g.Key))
                            {
                                

                                @foreach (var eq in grupo)
                                {
                                    <MudSelectItem T="int?" Value="(int?)eq.Id">
                                        <div class="d-flex align-center gap-1">
                                            <img src="@eq.FlagUrl" style="height:14px;" />
                                            @eq.Nombre
                                        </div>
                                    </MudSelectItem>
                                }
                               
                            }
                        }
                        else
                        {
                            @foreach (var eq in GetCandidatosParaSlot(
                                    pred.Partido.SlotVisitante,
                                    pred.EquipoLocalPredichoId,
                                    pred.Id))
                            {
                                <MudSelectItem T="int?" Value="(int?)eq.Id">
                                    <div class="d-flex align-center gap-1">
                                        <img src="@eq.FlagUrl" style="height:14px;" />
                                        @eq.Nombre
                                    </div>
                                </MudSelectItem>
                            }
                        }
                    </MudSelect>
                        @if (!_soloLectura && pred.EquipoVisitantePredichoId.HasValue)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                           Size="Size.Small" Color="Color.Error"
                                           OnClick="async () => await GuardarKoVisitante(pred, null)" />
                        }
                        @if (TieneCheckmark($"kov-{pred.Id}"))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                     Color="Color.Success" Size="Size.Small" />
                        }
                    </div>
                </div>
            </div>
        </MudPaper>;

    RenderFragment FilaFinalEquipo(string label, string campo, int? valorActual, Action<int?> setter) =>
        @<MudItem xs="12" sm="6">
            <div class="d-flex align-center gap-2 mb-2">
                <MudText Typo="Typo.body2" Style="min-width:180px;">@label</MudText>
                <MudSelect T="int?" Value="valorActual"
                           ValueChanged="async v => { var ant = valorActual; setter(v); await GuardarFinal(campo, ant.HasValue, v.HasValue); }"
                           Disabled="_soloLectura" Dense="true" Variant="Variant.Outlined"
                           Style="min-width:180px;" Placeholder="Seleccionar">
                    <MudSelectItem T="int?" Value="(int?)null">-- Seleccionar --</MudSelectItem>
                    @foreach (var eq in _equipos)
                    {
                        <MudSelectItem T="int?" Value="(int?)eq.Id">
                            <div class="d-flex align-center gap-2">
                                <img src="@eq.FlagUrl" style="height:14px;" /> @eq.Nombre
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>
                @if (TieneCheckmark($"f-{campo}"))
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
            </div>
        </MudItem>;

    RenderFragment FilaScore(string label, string campoL, string campoV,
        int? golesL, int? golesV, Action<int?> setL, Action<int?> setV) =>
        @<MudItem xs="12" sm="6">
            <MudText Typo="Typo.body2" Class="mb-1">@label</MudText>
            <div class="d-flex align-center gap-2">
                <MudNumericField T="int?" Value="golesL"
                                 ValueChanged="async v => { var ant = golesL; setL(v); await GuardarFinal(campoL, ant.HasValue, v.HasValue); }"
                                 Disabled="_soloLectura" Min="0" Max="99"
                                 Variant="Variant.Outlined" Dense="true" Style="width:70px;" />
                <MudText>-</MudText>
                <MudNumericField T="int?" Value="golesV"
                                 ValueChanged="async v => { var ant = golesV; setV(v); await GuardarFinal(campoV, ant.HasValue, v.HasValue); }"
                                 Disabled="_soloLectura" Min="0" Max="99"
                                 Variant="Variant.Outlined" Dense="true" Style="width:70px;" />
                @if (TieneCheckmark($"f-{campoL}") || TieneCheckmark($"f-{campoV}"))
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
            </div>
        </MudItem>;
}
