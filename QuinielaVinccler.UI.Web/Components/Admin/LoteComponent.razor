<MudContainer Class="pa-4">
    <MudText Typo="Typo.h6" Class="mb-3">Generar lote de planillas</MudText>

    @if (_quinielaCerrada)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true"
                  Icon="@Icons.Material.Filled.Lock">
            La quiniela está cerrada. No se pueden generar nuevas planillas ni eliminar lotes existentes.
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudNumericField @bind-Value="_cantidad"
                             Label="Cantidad de planillas"
                             Variant="Variant.Outlined"
                             Disabled="_quinielaCerrada"
                             Min="1" Max="50" />
        </MudItem>
        <MudItem xs="12" sm="4" Class="d-flex align-center">
            <MudTooltip Text="@(_quinielaCerrada ? "La quiniela está cerrada. No se pueden generar más planillas." : "")"
                        Disabled="@(!_quinielaCerrada)" Placement="Placement.Top">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="GenerarPlanillas"
                           Disabled="_generando || _quinielaCerrada"
                           StartIcon="@Icons.Material.Filled.Print">
                    @if (_generando)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Generando...</span>
                    }
                    else
                    {
                        <span>Generar Lote</span>
                    }
                </MudButton>
            </MudTooltip>
        </MudItem>
    </MudGrid>

    @if (_ultimoLote is not null)
    {
        <MudAlert Severity="Severity.Success" Class="mt-4">
            Lote <strong>@_ultimoLote.Codigo</strong> generado con @_ultimoLote.Planillas.Count planillas.
        </MudAlert>
    }

    @if (!string.IsNullOrEmpty(_error) && _ultimoLote is null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
    }

    @if (_lotes.Any())
    {
        @* ── Header con totales y botón exportar ── *@
        <div class="d-flex align-center justify-space-between mt-6 mb-3 flex-wrap gap-2">
            <MudText Typo="Typo.h6">Lotes generados</MudText>
            <div class="d-flex align-center gap-2 flex-wrap">

                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           Href="@GetReporteUrl()"
                           Target="_blank">
                    Exportar PDF
                </MudButton>

                <MudChip T="string"
                         Color="Color.Primary"
                         Size="Size.Small"
                         Variant="@(_filtro == FiltroPlanilla.Total ? Variant.Filled : Variant.Outlined)"
                         Icon="@Icons.Material.Filled.Inventory2"
                         OnClick="() => AplicarFiltro(FiltroPlanilla.Total)"
                         Style="cursor:pointer;">
                    @_lotes.Sum(l => l.Cantidad) planillas en total
                </MudChip>
                <MudChip T="string"
                         Color="Color.Success"
                         Size="Size.Small"
                         Variant="@(_filtro == FiltroPlanilla.Asignadas ? Variant.Filled : Variant.Outlined)"
                         Icon="@Icons.Material.Filled.CheckCircle"
                         OnClick="() => AplicarFiltro(FiltroPlanilla.Asignadas)"
                         Style="cursor:pointer;">
                    @_lotes.Sum(l => l.Planillas.Count(p => p.IsAssigned)) asignadas
                </MudChip>
                <MudChip T="string"
                         Color="Color.Warning"
                         Size="Size.Small"
                         Variant="@(_filtro == FiltroPlanilla.SinAsignar ? Variant.Filled : Variant.Outlined)"
                         Icon="@Icons.Material.Filled.PendingActions"
                         OnClick="() => AplicarFiltro(FiltroPlanilla.SinAsignar)"
                         Style="cursor:pointer;">
                    @_lotes.Sum(l => l.Planillas.Count(p => !p.IsAssigned)) sin asignar
                </MudChip>
            </div>
        </div>

        @if (_filtro != FiltroPlanilla.Total)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3"
                      ShowCloseIcon="true" CloseIconClicked="() => AplicarFiltro(FiltroPlanilla.Total)">
                Mostrando solo planillas <strong>@(_filtro == FiltroPlanilla.Asignadas ? "asignadas" : "sin asignar")</strong>.
                Los lotes sin planillas de este tipo no aparecen.
            </MudAlert>
        }

        @foreach (var lote in LotesFiltrados())
        {
            var planillasVisibles = PlanillasFiltradas(lote);

            <MudExpansionPanel Class="mb-2"
                               ExpandedChanged="expandido => OnLoteExpanded(lote, expandido)">
                <TitleContent>
                    <div class="d-flex align-center gap-4 flex-wrap">
                        <MudText Typo="Typo.subtitle1"><strong>@lote.Codigo</strong></MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                            @if (_filtro == FiltroPlanilla.Total)
                            {
                                <span>@lote.Cantidad planillas</span>
                            }
                            else
                            {
                                <span>@planillasVisibles.Count de @lote.Cantidad</span>
                            }
                        </MudChip>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            @lote.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </MudText>
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                   Href="@($"/api/lote/{lote.Id}/pdf")"
                                   Target="_blank">
                            Imprimir PDF
                        </MudButton>
                        <MudTooltip Text="@(_quinielaCerrada ? "La quiniela está cerrada. No se pueden eliminar lotes." : "")"
                                    Disabled="@(!_quinielaCerrada)" Placement="Placement.Top">
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       Disabled="_quinielaCerrada"
                                       OnClick="() => ConfirmarEliminarLote(lote)">
                                Eliminar
                            </MudButton>
                        </MudTooltip>
                    </div>
                </TitleContent>
                <ChildContent>
                    <MudTable Items="planillasVisibles" Hover="true" Striped="true" Dense="true">
                        <HeaderContent>
                            <MudTh>Código</MudTh>
                            <MudTh>Usuario</MudTh>
                            <MudTh>Estado</MudTh>
                            <MudTh Style="width:180px;">Progreso</MudTh>
                            <MudTh Style="width:50px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Codigo</MudTd>
                            <MudTd>@(context.User?.FullName ?? "—")</MudTd>
                            <MudTd>
                                @if (context.IsAssigned)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Asignada</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">Sin asignar</MudChip>
                                }
                            </MudTd>
                            <MudTd>
                                @if (context.IsAssigned)
                                {
                                    var prog = GetProgreso(lote.Id, context.Id);
                                    if (prog == -1)
                                    {
                                        <MudProgressLinear Indeterminate="true" Color="Color.Primary"
                                                           Size="Size.Small" Rounded="true" />
                                    }
                                    else
                                    {
                                        var pct = (int)Math.Round(prog * 100.0 / 149);
                                        var color = pct == 100 ? Color.Success : pct > 50 ? Color.Info : Color.Warning;
                                        <div class="d-flex align-center gap-2">
                                            <MudProgressLinear Value="pct" Max="100" Color="@color"
                                                               Size="Size.Small" Rounded="true"
                                                               Style="flex:1;" />
                                            <MudText Typo="Typo.caption" Style="white-space:nowrap;">
                                                @prog/149
                                            </MudText>
                                        </div>
                                    }
                                }
                            </MudTd>
                            <MudTd>
                                @if (context.IsAssigned)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="() => AbrirModal(context)" />
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </ChildContent>
            </MudExpansionPanel>
        }
    }
</MudContainer>

<MudDialog @bind-Visible="_showConfirmDelete">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar lote</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            ¿Estás seguro que deseas eliminar el lote <strong>@_seleccionado?.Codigo</strong>
            con <strong>@_seleccionado?.Cantidad</strong> planillas?
        </MudText>
        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick='() => { _showConfirmDelete = false; _error = ""; }'>Cancelar</MudButton>
        <MudButton Color="Color.Error"
                   Variant="Variant.Filled"
                   OnClick="Eliminar">
            Eliminar
        </MudButton>
    </DialogActions>
</MudDialog>
