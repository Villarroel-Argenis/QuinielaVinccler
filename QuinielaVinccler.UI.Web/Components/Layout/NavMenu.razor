
<AuthorizeView>
    <Authorized>
        <div class="pa-4 mb-2">
            <div class="d-flex align-center gap-3 mb-1">
                <MudAvatar Color="Color.Primary" Size="Size.Medium">
                    @GetInitials(context.User.FindFirst("FullName")?.Value)
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.body1" Style="font-weight:600; line-height:1.2;">
                        @context.User.FindFirst("FullName")?.Value
                    </MudText>
                    @if (context.User.IsInRole("Admin"))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Admin</MudText>
                    }
                </div>
            </div>
            <MudDivider Class="mt-3" />
        </div>

        <MudNavMenu>
            <MudNavLink Href="/mis-planillas"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.GridOn">
                Mis Planillas
            </MudNavLink>
            <MudNavLink Href="/ranking"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Star">
                Ranking
            </MudNavLink>

            <AuthorizeView Roles="Admin" Context="adminCtx">
                <Authorized>
                    <MudDivider Class="my-2" />
                    <MudNavGroup Title="Administración"
                                 Icon="@Icons.Material.Filled.AdminPanelSettings"
                                 Expanded="true">
                        <MudNavLink Href="/admin"
                                    Icon="@Icons.Material.Filled.Dashboard">
                            Panel Admin
                        </MudNavLink>
                    </MudNavGroup>
                </Authorized>
            </AuthorizeView>
        </MudNavMenu>
    </Authorized>
</AuthorizeView>