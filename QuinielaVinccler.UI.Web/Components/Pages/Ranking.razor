@* Components/Pages/Ranking.razor *@
@page "/ranking"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Registrado")]
@using QuinielaVinccler.UI.Web.Services

<PageTitle>Ranking — Quiniela Vinccler 2026</PageTitle>

<style>
    .ranking-fila-actual td {
        background-color: #77ea7d !important;
        font-weight: 600;
    }

    .ranking-podio-1 {
        color: #FFD700;
    }

    .ranking-podio-2 {
        color: #C0C0C0;
    }

    .ranking-podio-3 {
        color: #CD7F32;
    }

    .premios-card {
        border-left: 4px solid var(--mud-palette-primary);
    }
</style>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">

    <div class="d-flex align-center justify-space-between mb-4 flex-wrap gap-2">
        <MudText Typo="Typo.h4">🏆 Ranking</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @_total participante@(_total == 1 ? "" : "s")
        </MudText>
    </div>

    <MudExpansionPanels Class="mb-5" Elevation="1">
        <MudExpansionPanel Text="Ver premios">
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-3 premios-card" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6" Class="ranking-podio-1">🥇 1er Premio</MudText>
                        <MudText Typo="Typo.body1">$2,000 + 50% de lo recaudado</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-3 premios-card" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6" Class="ranking-podio-2">🥈 2do Premio</MudText>
                        <MudText Typo="Typo.body1">$1,000 + 30% de lo recaudado</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-3 premios-card" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6" Class="ranking-podio-3">🥉 3er Premio</MudText>
                        <MudText Typo="Typo.body1">$500 + 20% de lo recaudado</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-3" Style="border-left: 4px solid var(--mud-palette-error);"
                              Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6">🤡 Menor puntaje</MudText>
                        <MudText Typo="Typo.body1">$2,000</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                * En caso de empate, el premio se reparte proporcionalmente.
            </MudText>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @if (!_quinielaCerrada)
    {
        <MudPaper Elevation="2" Class="pa-8 text-center rounded-lg mt-4">
            <MudIcon Icon="@Icons.Material.Filled.Lock"
                     Color="Color.Primary"
                     Style="font-size:3rem; opacity:.5;"
                     Class="mb-3" />
            <MudText Typo="Typo.h6" Class="mb-2">El ranking se mostrará al cerrar la quiniela</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Mientras los participantes pueden seguir editando sus predicciones,
                las posiciones se mostraran a medida que tengamos los resultados.
            </MudText>
        </MudPaper>
    }
    else
    {
        <div class="d-flex align-center gap-4 mb-3 flex-wrap">
            <MudSwitch T="bool" Value="_soloMias" ValueChanged="ToggleSoloMias"
                       Color="Color.Primary" Label="Ver solo mis planillas" />

            @if (!_soloMias)
            {
                <div class="d-flex align-center gap-2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Filas por página:</MudText>
                    <MudSelect T="int" Value="_pageSize" ValueChanged="CambiarPageSize"
                               Dense="true" Margin="Margin.Dense" Style="width:90px">
                        <MudSelectItem Value="10">10</MudSelectItem>
                        <MudSelectItem Value="20">20</MudSelectItem>
                        <MudSelectItem Value="50">50</MudSelectItem>
                    </MudSelect>
                </div>
            }
        </div>

        @if (_cargando)
        {
            <div class="d-flex justify-center pa-12">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (_ranking.Count == 0)
        {
            <MudAlert Severity="Severity.Info">Aún no hay planillas participando.</MudAlert>
        }
        else if (_filtradas.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No tienes planillas vinculadas.</MudAlert>
        }
        else
        {
            var posicionesDistintas = _ranking.Select(x => x.Posicion).Distinct().OrderBy(x => x).ToList();

            <MudTable Items="_paginadas" Hover="true" Dense="true" Elevation="2"
                      RowClassFunc="FilaClass" T="RankingItemDto">
                <HeaderContent>
                    <MudTh Style="width:60px">#</MudTh>
                    <MudTh>Participante</MudTh>
                    <MudTh>Planilla</MudTh>
                    <MudTh Style="text-align:right">Puntaje</MudTh>
                    <MudTh Style="width:48px"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        @{
                            var rango = posicionesDistintas.IndexOf(context.Posicion) + 1;
                        }
                        @if (rango == 1)
                        {
                            <span class="ranking-podio-1" style="font-size:1.3rem">🥇</span>
                        }
                        else if (rango == 2)
                        {
                            <span class="ranking-podio-2" style="font-size:1.3rem">🥈</span>
                        }
                        else if (rango == 3)
                        {
                            <span class="ranking-podio-3" style="font-size:1.3rem">🥉</span>
                        }
                        else if (context.Posicion == _ultimaPosicion)
                        {
                            <span style="font-size:1.1rem" title="Menor puntaje">🙃</span>
                        }
                        else
                        {
                            @GetCorrelativo(context)
                        }
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@context.Nombre</MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@context.CodigoPlanilla</MudText>
                    </MudTd>
                    <MudTd Style="text-align:right">
                        <MudText Typo="Typo.body2"><strong>@context.PuntajeTotal</strong> pts</MudText>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="() => AbrirModal(context)" />
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @if (MostrarPaginador)
            {
                <div class="d-flex justify-center mt-4">
                    <MudPagination Color="Color.Primary"
                                   Count="@TotalPaginas"
                                   Selected="_paginaActual"
                                   SelectedChanged="CambiarPagina"
                                   ShowFirstButton="true" ShowLastButton="true" />
                </div>
            }
        }
    }
</MudContainer>