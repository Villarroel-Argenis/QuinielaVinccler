@namespace QuinielaVinccler.UI.Web.Components.Admin

<div class="pa-4">

    @* ── Buscador ────────────────────────────────────────────────────────── *@
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Busca por código de planilla, nombre, email o cédula del participante.
    </MudText>

    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="8">
            <MudTextField @bind-Value="_termino"
                          Label="Buscar planilla"
                          Placeholder="P-12345678 / nombre / email / cédula"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          OnKeyDown="HandleKeyDown"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Disabled="_buscando" />
        </MudItem>
        <MudItem xs="12" sm="4" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="Buscar"
                       Disabled="_buscando || string.IsNullOrWhiteSpace(_termino)"
                       StartIcon="@Icons.Material.Filled.Search">
                @if (_buscando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Buscando...</span>
                }
                else
                {
                    <span>Buscar</span>
                }
            </MudButton>
        </MudItem>
    </MudGrid>

    @* ── Resultados ───────────────────────────────────────────────────────── *@
    @if (_resultados is not null)
    {
        @if (_resultados.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No se encontraron planillas vinculadas con ese criterio.
            </MudAlert>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                @_resultados.Count resultado(s) encontrado(s)
            </MudText>

            @foreach (var p in _resultados)
            {
                <MudPaper Elevation="1" Class="pa-3 mb-3 rounded">
                    <div class="d-flex align-center justify-space-between flex-wrap gap-2">

                        <div>
                            <div class="d-flex align-center gap-2 mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber"
                                         Color="Color.Primary" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2" Style="font-weight:700;">
                                    @p.Codigo
                                </MudText>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@GetColorEstado(p.Estado)">
                                    @GetLabelEstado(p.Estado)
                                </MudChip>
                                @if (p.PuntajeTotal > 0)
                                {
                                    <MudChip T="string" Size="Size.Small"
                                             Color="Color.Warning"
                                             Icon="@Icons.Material.Filled.Star">
                                        @p.PuntajeTotal pts
                                    </MudChip>
                                }
                            </div>
                            <MudText Typo="Typo.body2">
                                <strong>@p.UsuarioNombre</strong>
                                <span class="mud-text-secondary"> · @p.UsuarioEmail · CI: @p.UsuarioCI</span>
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Vinculada: @p.AssignedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                        </div>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.LinkOff"
                                   OnClick="() => AbrirConfirmacion(p)">
                            Desvincular
                        </MudButton>
                    </div>
                </MudPaper>
            }
        }
    }
</div>

@* ── Dialog de confirmación ───────────────────────────────────────────────── *@
<MudDialog @bind-Visible="_showConfirm">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6">Desvincular planilla</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-3">
            ¿Estás seguro que deseas desvincular la planilla
            <strong>@_seleccionada?.Codigo</strong> del usuario
            <strong>@_seleccionada?.UsuarioNombre</strong>?
        </MudText>
        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
            Esta acción <strong>no se puede deshacer</strong>. Se eliminarán:
            <ul style="margin: 6px 0 0 16px;">
                <li>Todas las predicciones de fase de grupos</li>
                <li>Todas las predicciones de fases eliminatorias</li>
                <li>Todas las predicciones finales</li>
                <li>Los puntos acumulados (@(_seleccionada?.PuntajeTotal ?? 0) pts)</li>
            </ul>
        </MudAlert>
        <MudAlert Severity="Severity.Warning" Dense="true">
            La planilla quedará disponible para ser vinculada nuevamente por otro usuario.
        </MudAlert>

        @if (_errorDesvincular is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">
                @_errorDesvincular
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CerrarConfirmacion" Disabled="_desvinculando">
            Cancelar
        </MudButton>
        <MudButton Color="Color.Error"
                   Variant="Variant.Filled"
                   OnClick="EjecutarDesvincular"
                   Disabled="_desvinculando"
                   StartIcon="@Icons.Material.Filled.LinkOff">
            @if (_desvinculando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Desvinculando...</span>
            }
            else
            {
                <span>Sí, desvincular</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
